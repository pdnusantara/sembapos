# Salin ke .env dan sesuaikan. Di VPS: isi DATABASE_URL + SECRET_KEY kuat.

# PostgreSQL (contoh lokal / VPS sama mesin)
# DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/NAMA_DB

# Jangan pakai karakter mentah di password tanpa URL-encode; gunakan urllib.parse.quote_plus jika perlu.
SECRET_KEY=ganti-dengan-string-acak-panjang

# Opsional (langganan tenant)
# SUBSCRIPTION_GRACE_DAYS=0
# SUBSCRIPTION_EXPIRED_MODE=block_login
