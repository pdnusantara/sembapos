[Unit]
Description=Gunicorn Sembako POS (Flask)
After=network.target postgresql.service

[Service]
Type=simple
User=sembapos
Group=sembapos
WorkingDirectory=/home/sembapos/sembako-kuningan
Environment="PATH=/home/sembapos/sembako-kuningan/venv/bin"
ExecStart=/home/sembapos/sembako-kuningan/venv/bin/gunicorn -c deploy/gunicorn.conf.py wsgi:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
